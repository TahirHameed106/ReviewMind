# ReviewMind Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=reviewmind-server.database.windows.net
DB_USER=adminuser
DB_PASSWORD=YourPassword123!
DB_NAME=reviewmind
DB_ENCRYPTION=true
DB_TRUSTSERVERCERTIFICATE=false

# ============================================
# LLM API KEYS
# ============================================
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get free key at: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
ML_SERVICE_URL=http://localhost:8000

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
SESSION_SECRET=your_session_secret_key_here

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_DIFFICULTY=4

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_TO_FILE=false

# ============================================
# FEATURES
# ============================================
ENABLE_BLOCKCHAIN=true
ENABLE_CHAT=true
ENABLE_REPORTS=true
ENABLE_CORS=true

# ============================================
# NOTES
# ============================================
# - Groq API is free (limited requests)
# - Gemini API is free (limited requests)
# - Keep these keys secret! Never commit to git
# - Use different keys for dev/production
# - Add .env to .gitignore
